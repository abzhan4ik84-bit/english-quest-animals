<!DOCTYPE html>
<html>
<head>
<title>English Quest Animals v0.15</title>

<style>
body{
font-family:Arial,sans-serif;
background:#4facfe;
padding:20px;
text-align:center;
}

h1{
color:white;
font-size:50px;
}

h2{
color:white;
margin-top:30px;
}

.cards{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:15px;
}

.card{
background:white;
width:170px;
padding:15px;
border-radius:20px;
cursor:pointer;
box-shadow:0 4px 10px rgba(0,0,0,0.2);
transition:0.3s;
}

.card:hover{
transform:scale(1.08);
}

.animal{
font-size:70px;
}

.word{
font-size:28px;
font-weight:bold;
margin-top:10px;
}

.sound{
font-size:30px;
margin-top:10px;
}
</style>
</head>

<body>

<h1>🌟 English Quest 🌟</h1>

<h2>🐶 Pets</h2>

<div class="cards">

<div class="card" onclick="speak('Dog')">
<div class="animal">🐶</div>
<div class="word">DOG</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Cat')">
<div class="animal">🐱</div>
<div class="word">CAT</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Rabbit')">
<div class="animal">🐰</div>
<div class="word">RABBIT</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Hamster')">
<div class="animal">🐹</div>
<div class="word">HAMSTER</div>
<div class="sound">🔊</div>
</div>

</div>

<h2>🇰🇿 Animals of Kazakhstan</h2>

<div class="cards">

<div class="card">

<div class="animal">🐺</div>

<div class="word">WOLF</div>

<div class="sound" onclick="speak('Wolf')">
🔊
</div>

<button onclick="showWolfFact()">
💡 Fact
</button>

<button onclick="showWolfSpeak()">
🎤 Speak
</button>

<div id="wolfInfo"></div>

</div>

<div class="card" onclick="speak('Fox')">
<div class="animal">🦊</div>
<div class="word">FOX</div>
<div class="sound">🔊</div>
</div>

<div class="card">

<div class="animal">🐪</div>

<div class="word">CAMEL</div>

<div class="sound" onclick="speak('Camel')">
🔊
</div>

<button onclick="showCamelFact()">
💡 Fact
</button>

<button onclick="showCamelSpeak()">
🎤 Speak
</button>

<div id="camelInfo"></div>

</div>

<div class="card" onclick="speak('Horse')">
<div class="animal">🐴</div>
<div class="word">HORSE</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Sheep')">
<div class="animal">🐑</div>
<div class="word">SHEEP</div>
<div class="sound">🔊</div>
</div>

<div class="card">

<div class="animal">🦅</div>

<div class="word">GOLDEN EAGLE</div>

<div class="sound" onclick="speak('Golden Eagle')">
🔊
</div>

<button onclick="showFact()">
💡 Fact
</button>

<button onclick="showSpeak()">
🎤 Speak
</button>

<div id="eagleInfo"></div>

</div>

</div>

<h2>🌍 Exotic Animals</h2>

<div class="cards">

<div class="card" onclick="speak('Lion')">
<div class="animal">🦁</div>
<div class="word">LION</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Elephant')">
<div class="animal">🐘</div>
<div class="word">ELEPHANT</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Giraffe')">
<div class="animal">🦒</div>
<div class="word">GIRAFFE</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Zebra')">
<div class="animal">🦓</div>
<div class="word">ZEBRA</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Monkey')">
<div class="animal">🐒</div>
<div class="word">MONKEY</div>
<div class="sound">🔊</div>
</div>

<div class="card" onclick="speak('Panda')">
<div class="animal">🐼</div>
<div class="word">PANDA</div>
<div class="sound">🔊</div>
</div>

</div>

<script>
function speak(word){
let speech = new SpeechSynthesisUtterance(word);
speech.lang = "en-US";
speech.rate = 0.8;
speechSynthesis.speak(speech);
}
function showFact(){

document.getElementById("eagleInfo").innerHTML =
"<p><b>Interesting Fact:</b><br>The Golden Eagle is a symbol of Kazakhstan.</p>";

}

function showSpeak(){

document.getElementById("eagleInfo").innerHTML =
"<p><b>Speaking Challenge:</b><br>Have you seen an eagle?</p>";

}
function showCamelFact(){

document.getElementById("camelInfo").innerHTML =
"<p><b>Interesting Fact:</b><br>Camels can live in the desert.</p>";

}

function showCamelSpeak(){

document.getElementById("camelInfo").innerHTML =
"<p><b>Speaking Challenge:</b><br>Would you like to ride a camel?</p>";

}

function showWolfFact(){

document.getElementById("wolfInfo").innerHTML =
"<p><b>Interesting Fact:</b><br>Wolves live in groups called packs.</p>";

}

function showWolfSpeak(){

document.getElementById("wolfInfo").innerHTML =
"<p><b>Speaking Challenge:</b><br>Do you like wolves?</p>";

}
const quizQuestions = [

{
question:"Which animal can fly?",
answers:["Golden Eagle","Camel","Horse"],
correct:"Golden Eagle"
},

{
question:"Which animal lives in Kazakhstan?",
answers:["Wolf","Lion","Panda"],
correct:"Wolf"
},

{
question:"Which animal is a pet?",
answers:["Cat","Elephant","Zebra"],
correct:"Cat"
},

{
question:"Which animal lives in the desert?",
answers:["Camel","Rabbit","Panda"],
correct:"Camel"
},

{
question:"Which animal has a long neck?",
answers:["Giraffe","Dog","Fox"],
correct:"Giraffe"
}

];

let currentQuestion = 0;
let score = 0;

function startQuiz(){

currentQuestion = 0;
score = 0;

showQuestion();

}

function showQuestion(){

if(currentQuestion >= quizQuestions.length){

document.getElementById("quizArea").innerHTML =
"<h2>🏆 Great Job!</h2>" +
"<h3>Score: " + score + "/" + quizQuestions.length + "</h3>" +
"<h2>⭐ You earned a Class Star!</h2>";

return;
}

const q = quizQuestions[currentQuestion];

let html =
"<h2>" + q.question + "</h2>";

q.answers.forEach(answer => {

html +=
"<button onclick=\"checkAnswer('" + answer + "')\" style='display:block;margin:10px auto;padding:15px 25px;font-size:24px;border-radius:15px;'>"
+ answer +
"</button>";

});

document.getElementById("quizArea").innerHTML = html;

}

function checkAnswer(answer){

if(answer === quizQuestions[currentQuestion].correct){

score++;

alert("⭐ Correct!");

}else{

alert("❌ Try Again!");
}

currentQuestion++;

showQuestion();

}
</script>

<hr style="margin-top:50px;">

<h2>🎮 Animal Quiz</h2>

<button onclick="startQuiz()"
style="
font-size:30px;
padding:20px 40px;
border:none;
border-radius:20px;
background:gold;
cursor:pointer;
margin-top:20px;">
START QUIZ
</button>

<div id="quizArea" style="margin-top:30px;"></div> 
</body>
</html>
